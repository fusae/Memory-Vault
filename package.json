{
  "name": "memory-vault",
  "version": "0.1.0",
  "description": "MCP Memory Server - Your AI memory belongs to you",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memoryvault/memory-vault"
  },
