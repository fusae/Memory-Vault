MEMORY_DB_PATH=~/.memoryvault/memory.db
OLLAMA_BASE_URL=http://localhost:11434

# E2EE encryption (optional — set after running: memory-vault-cli init-encryption)
# MEMORYVAULT_PASSPHRASE=your-secret-passphrase

# Supabase cloud sync (optional — set via: memory-vault-cli setup)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Dashboard port
# DASHBOARD_PORT=3080
